# Hugging Face API Configuration
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Model Configuration
MODEL_NAME=omni-video-v1
MODEL_DEVICE=cuda

# GPU Configuration
GPU_DEVICE=0
ENABLE_GPU=true

# Video Generation Parameters
DEFAULT_DURATION=5
DEFAULT_RESOLUTION=1280x720
DEFAULT_FPS=24

# Workflow Configuration
WORKFLOW_DIR=./workflows
OUTPUT_DIR=./outputs

# Logging
LOG_LEVEL=INFO
